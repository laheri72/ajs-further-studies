rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function adminDoc() {
      return /databases/$(database)/documents/admins/$(request.auth.token.email.lower());
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email is string
        && exists(adminDoc())
        && get(adminDoc()).data.active == true;
    }

    function isSuperAdmin() {
      return isAdmin() && request.auth.token.email == 'idrislaheri72@gmail.com';
    }

    function isWhitelistedStudent() {
      return signedIn()
        && request.auth.token.email is string
        && exists(/databases/$(database)/documents/student_whitelist/$(request.auth.token.email.lower()));
    }

    function validStatus(value) {
      return value in ['pending', 'on-hold', 'approved'];
    }

    function isAutoApprovedStudent(data) {
      return (data.nextQualificationIntent == 'not_now'
          && data.requiresAssistance == false)
        || (data.nextQualificationIntent == 'already_pursuing'
          && data.needsLeavesThisYear == false);
    }

    function isStudentEmail() {
      return signedIn()
        && request.auth.token.email is string
        && (request.auth.token.email.lower().matches('^[0-9]{5}@jameasaifiyah\\.edu$') || isWhitelistedStudent());
    }

    function trMatchesEmail(trNo) {
      return trNo is string
        && trNo.matches('^[0-9]{5}$')
        && (trNo + '@jameasaifiyah.edu' == request.auth.token.email.lower()
            || (isWhitelistedStudent() 
                && get(/databases/$(database)/documents/student_whitelist/$(request.auth.token.email.lower())).data.trNo == trNo));
    }

    function trBelongsToRequestUser(trNo) {
      return trNo is string
        && trMatchesEmail(trNo)
        && existsAfter(/databases/$(database)/documents/trIndex/$(trNo))
        && getAfter(/databases/$(database)/documents/trIndex/$(trNo)).data.uid == request.auth.uid;
    }

    function validTashjeeStatus(value) {
      return value in ['pending', 'approved', 'rejected'];
    }

    function validTashjeeUrl(url) {
      return url is string && url.matches('^https://res\\.cloudinary\\.com/.+\\.(jpg|jpeg|png|webp)$');
    }

    function validCloudinaryImageUrl(url) {
      return url is string && url.matches('^https://res\\.cloudinary\\.com/.+\\.(jpg|jpeg|png|webp)$');
    }

    function optionalShortString(data, field, maxSize) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxSize);
    }

    function validQualificationData(data) {
      return data.keys().hasOnly([
          'title',
          'institute',
          'yearObtained',
          'grade',
          'notes',
          'createdAt',
          'updatedAt'
        ])
        && data.keys().hasAll(['title', 'createdAt', 'updatedAt'])
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 120
        && optionalShortString(data, 'institute', 160)
        && optionalShortString(data, 'yearObtained', 20)
        && optionalShortString(data, 'grade', 80)
        && optionalShortString(data, 'notes', 1000)
        && data.createdAt is timestamp
        && data.updatedAt == request.time;
    }

    function validExamProofData(data) {
      return data.keys().hasOnly([
          'state',
          'proofUrl',
          'proofPreviewUrl',
          'proofPublicId',
          'proofAssetId',
          'proofDeleteToken',
          'format',
          'updatedAt'
        ])
        && data.keys().hasAll([
          'state',
          'proofUrl',
          'proofPreviewUrl',
          'proofPublicId',
          'proofAssetId',
          'proofDeleteToken',
          'format',
          'updatedAt'
        ])
        && data.state in ['uploaded', 'not_generated_yet']
        && data.proofUrl is string
        && data.proofPreviewUrl is string
        && data.proofPublicId is string
        && data.proofAssetId is string
        && data.proofDeleteToken is string
        && data.format is string
        && data.proofPublicId.size() <= 200
        && data.proofAssetId.size() <= 200
        && data.proofDeleteToken.size() <= 300
        && data.format.size() <= 20
        && data.updatedAt == request.time
        && ((data.state == 'uploaded'
            && validCloudinaryImageUrl(data.proofUrl)
            && validCloudinaryImageUrl(data.proofPreviewUrl))
          || (data.state == 'not_generated_yet'
            && data.proofUrl == ''
            && data.proofPreviewUrl == ''
            && data.proofPublicId == ''
            && data.proofAssetId == ''
            && data.proofDeleteToken == ''
            && data.format == ''));
    }

    function studentResubmissionKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'status',
          'uid',
          'email',
          'trNo',
          'fullName',
          'qualifications',
          'otherQual',
          'nextQualificationIntent',
          'hasThoughtAboutNext',
          'stage',
          'needsLeavesThisYear',
          'requiresAssistance',
          'degreeApplying',
          'institution',
          'studyCommitment',
          'razaDays',
          'examMonths',
          'clashWithMiqaat',
          'clashEvents',
          'clashDetails',
          'needsLaptop',
          'laptopJustification',
          'additionalNotes',
          'submittedAt',
          'updatedAt'
        ]);
    }

    match /admins/{email} {
      allow read: if isSuperAdmin() || (signedIn() && request.auth.token.email.lower() == email.lower());
      allow create: if isSuperAdmin()
        && request.resource.data.email == email
        && request.resource.data.active is bool
        && request.resource.data.active == true
        && request.resource.data.displayName is string
        && request.resource.data.createdBy == request.auth.token.email
        && request.resource.data.updatedBy == request.auth.token.email
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'active',
          'createdAt',
          'createdBy',
          'updatedAt',
          'updatedBy'
        ]);
      allow update: if isSuperAdmin()
        && request.resource.data.email == email
        && request.resource.data.active is bool
        && request.resource.data.active == true
        && request.resource.data.displayName is string
        && request.resource.data.updatedBy == request.auth.token.email
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['active', 'displayName', 'email', 'updatedAt', 'updatedBy']);
      allow delete: if isSuperAdmin() && email != 'idrislaheri72@gmail.com';
    }

    match /student_whitelist/{email} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.email.lower() == email.lower());
      allow write: if isSuperAdmin();
    }

    match /tashjee_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /tashjee_requests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.studentId == request.auth.uid);

      allow create: if signedIn()
        && isStudentEmail()
        && request.resource.data.requestId == requestId
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.studentName is string
        && request.resource.data.requestType is string
        && request.resource.data.detailedReason is string
        && validTashjeeUrl(request.resource.data.proofUrl)
        && request.resource.data.status == 'pending'
        && request.resource.data.adminRemarks == ''
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if isAdmin()
        && validTashjeeStatus(request.resource.data.status)
        && request.resource.data.adminRemarks is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'adminRemarks', 'updatedAt']);

      allow delete: if isAdmin()
        || (signedIn()
          && resource.data.studentId == request.auth.uid
          && resource.data.status in ['pending', 'on-hold']);
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid)
        && isStudentEmail()
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && trBelongsToRequestUser(request.resource.data.trNo);
      allow delete: if false;
    }

    match /trIndex/{trNo} {
      allow read: if signedIn();
      allow create: if signedIn()
        && isStudentEmail()
        && trNo == request.resource.data.trNo
        && trMatchesEmail(trNo)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && !exists(/databases/$(database)/documents/trIndex/$(trNo));
      allow update: if signedIn()
        && isStudentEmail()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && trNo == request.resource.data.trNo
        && trMatchesEmail(trNo);
      allow delete: if false;
    }

    match /students/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && isStudentEmail()
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && trBelongsToRequestUser(request.resource.data.trNo)
        && (request.resource.data.status == 'pending'
          || (request.resource.data.status == 'approved'
            && isAutoApprovedStudent(request.resource.data)))
        && request.resource.data.adminNotes == ''
        && !('reviewedAt' in request.resource.data)
        && !('reviewedBy' in request.resource.data);

      allow update: if isOwner(uid)
        && isStudentEmail()
        && (resource.data.status == 'on-hold'
          || (resource.data.status == 'pending' && !('submittedAt' in resource.data)))
        && (request.resource.data.status == 'pending'
          || (request.resource.data.status == 'approved'
            && isAutoApprovedStudent(request.resource.data)))
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && trBelongsToRequestUser(request.resource.data.trNo)
        && studentResubmissionKeysOnly();

      allow update: if isAdmin()
        && validStatus(request.resource.data.status)
        && (request.resource.data.status != 'on-hold'
          || (request.resource.data.adminNotes is string
            && request.resource.data.adminNotes.size() > 0))
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'adminNotes', 'reviewedAt', 'reviewedBy', 'updatedAt']);

      allow delete: if isAdmin();

      match /qualifications/{qualificationId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid)
          && isStudentEmail()
          && validQualificationData(request.resource.data)
          && request.resource.data.createdAt == request.time;
        allow update: if isOwner(uid)
          && isStudentEmail()
          && validQualificationData(request.resource.data)
          && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(uid) || isAdmin();
      }

      match /examProof/{proofId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update: if proofId == 'current'
          && isOwner(uid)
          && isStudentEmail()
          && validExamProofData(request.resource.data);
        allow delete: if false;
      }
    }
  }
}
